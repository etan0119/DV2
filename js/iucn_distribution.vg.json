{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Stewardship Levels: Protected Area Counts",
    "subtitle": "Distribution across IUCN Management Categories",
    "anchor": "start"
  },
  "width": "container",
  "height": 400,
  "data": {
    "url": "data/capad_metadata.csv",
    "format": {"type": "csv"}
  },
  "transform": [
    {
      "filter": "datum.IUCN != null && datum.IUCN != '' && datum.IUCN != 'null'"
    }
  ],
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "IUCN",
      "type": "nominal",
      "title": "IUCN Management Category",
      "sort": ["Ia", "Ib", "II", "III", "IV", "V", "VI"],
      "axis": {"labelAngle": 0}
    },
    "y": {
      "aggregate": "count",
      "type": "quantitative",
      "title": "Number of Sites"
    },
    "color": {
      "field": "IUCN",
      "type": "nominal",
      "scale": {"scheme": "greens"},
      "legend": null
    },
    "tooltip": [
      {"field": "IUCN", "type": "nominal", "title": "Category"},
      {"aggregate": "count", "type": "quantitative", "title": "Total Protected Areas"}
    ]
  }
}
