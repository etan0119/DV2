{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "The Paradox of Protection: Increasing Area vs. Declining Species",
    "subtitle": "Relative Abundance Index (1985 = 1.0) for Threatened Groups",
    "anchor": "start"
  },
  "width": "container",
  "height": 400,
  "data": {
    "url": "data/tsx_index.csv",
    "format": {"type": "csv"}
  },
  "mark": {"type": "line", "point": true},
  "encoding": {
    "x": {"field": "Year", "type": "temporal", "title": "Year"},
    "y": {"field": "Relative_Abundance", "type": "quantitative", "title": "Relative Abundance Index"},
    "color": {
      "field": "Group",
      "type": "nominal",
      "scale": {"scheme": "category10"},
      "title": "Taxonomic Group"
    },
    "tooltip": [
      {"field": "Year", "type": "temporal"},
      {"field": "Group", "type": "nominal"},
      {"field": "Relative_Abundance", "type": "quantitative", "format": ".2f"}
    ]
  }
}
