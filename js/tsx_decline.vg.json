{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "The Paradox of Protection: Increasing Area vs. Declining Species",
    "subtitle": "Relative Abundance Index (1985 = 1.0) for Threatened Groups",
    "anchor": "start",
    "offset": 20
  },
  "width": "container",
  "height": 400,
  "config": {
    "font": "Open Sans",
    "title": {
      "font": "Montserrat",
      "fontSize": 16,
      "fontWeight": "bold"
    },
    "axis": {
      "labelFont": "Open Sans",
      "titleFont": "Montserrat",
      "titleFontSize": 12,
      "titleFontWeight": "bold"
    },
    "legend": {
      "titleFont": "Montserrat",
      "titleFontSize": 12,
      "labelFont": "Open Sans",
      "labelFontSize": 11
    }
  },
  "data": {
    "url": "data/tsx_index.csv",
    "format": {"type": "csv"}
  },
  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeDash": [4, 4],
        "color": "red",
        "strokeWidth": 2
      },
      "encoding": {
        "y": {"datum": 1.0}
      }
    },
    {
      "data": {"values": [{"Year": 2022, "Relative_Abundance": 1.0, "Text": "1985 Baseline"}]},
      "mark": {
        "type": "text",
        "align": "right",
        "dx": -10,
        "dy": -8,
        "color": "red",
        "fontWeight": "bold"
      },
      "encoding": {
        "x": {"field": "Year", "type": "quantitative"},
        "y": {"field": "Relative_Abundance", "type": "quantitative"},
        "text": {"field": "Text"}
      }
    },
    {
      "mark": {"type": "line", "point": true},
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "title": "Year",
          "axis": {"format": "d"},
          "scale": {"zero": false}
        },
        "y": {
          "field": "Relative_Abundance",
          "type": "quantitative", 
          "title": "Relative Abundance Index"
        },
        "color": {
          "field": "Group",
          "type": "nominal",
          "scale": {
            "domain": ["Birds", "Amphibians", "Mammals", "Plants", "Reptiles"],
            "range": ["#2b8cbe", "#8856a7", "#e34a33", "#2ca25f", "#feb24c"]
          },
          "title": "Taxonomic Group"
        },
        "tooltip": [
          {"field": "Year", "type": "quantitative", "title": "Year", "format": "d"},
          {"field": "Group", "type": "nominal", "title": "Taxonomic Group"},
          {"field": "Relative_Abundance", "type": "quantitative", "title": "Abundance Index", "format": ".2f"}
        ]
      }
    }
  ]
}
