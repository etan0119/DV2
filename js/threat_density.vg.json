{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Protected Area Count by State and Type",
  "width": "container",
  "height": 300,
  "autosize": {"type": "fit", "contains": "padding"},
  "data": {
    "url": "data/capad_metadata.csv",
    "format": {"type": "csv"}
  },
  "transform": [
    {
      "filter": "datum.STATE != 'EXT'"
    },
    {
      "calculate": "datum.ENVIRON == 'T' ? 'Terrestrial' : 'Marine'",
      "as": "Environment"
    }
  ],
  "mark": "rect",
  "encoding": {
    "x": {"field": "STATE", "type": "nominal", "title": "State"},
    "y": {"field": "Environment", "type": "nominal", "title": null},
    "color": {
      "aggregate": "count",
      "type": "quantitative",
      "scale": {"scheme": "oranges"},
      "legend": {"title": "Count", "orient": "right"}
    },
    "tooltip": [
      {"field": "STATE", "type": "nominal"},
      {"field": "ENVIRON", "type": "nominal"},
      {"aggregate": "count", "type": "quantitative", "title": "Count"}
    ]
  }
}
