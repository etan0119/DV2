{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Havens of Hope: Fenced Sanctuaries vs. Open Parks",
    "subtitle": "Relative Abundance Index (1985 = 1.0) for Threatened Mammals by active management status",
    "anchor": "start",
    "offset": 20
  },
  "width": "container",
  "height": 400,
  "config": {
    "font": "Open Sans",
    "title": {
      "font": "Montserrat",
      "fontSize": 16,
      "fontWeight": "bold"
    },
    "axis": {
      "labelFont": "Open Sans",
      "titleFont": "Montserrat",
      "titleFontSize": 12,
      "titleFontWeight": "bold"
    },
    "legend": {
      "titleFont": "Montserrat",
      "titleFontSize": 12,
      "labelFont": "Open Sans",
      "labelFontSize": 11
    },
    "view": {"stroke": null}
  },
  "data": {
    "url": "data/tsx_mammal_management_trends.csv",
    "format": {"type": "csv"}
  },
  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeDash": [4, 4],
        "color": "gray",
        "strokeWidth": 1.5
      },
      "encoding": {
        "y": {"datum": 1.0}
      }
    },
    {
      "data": {"values": [{"Year": 2022, "Index_Value": 1.0, "Text": "1985 Baseline"}]},
      "mark": {
        "type": "text",
        "align": "right",
        "dx": -10,
        "dy": -8,
        "color": "gray",
        "fontWeight": "bold"
      },
      "encoding": {
        "x": {"field": "Year", "type": "quantitative"},
        "y": {"field": "Index_Value", "type": "quantitative"},
        "text": {"field": "Text"}
      }
    },
    {
      "mark": {"type": "line", "point": true, "strokeWidth": 3},
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "title": "Year",
          "axis": {"format": "d"},
          "scale": {"zero": false}
        },
        "y": {
          "field": "Index_Value",
          "type": "quantitative",
          "title": "Relative Abundance Index"
        },
        "color": {
          "field": "Management",
          "type": "nominal",
          "scale": {
            "domain": [
              "Fenced Havens & Islands (Predator-Free)",
              "Standard Open Landscapes (Unfenced/Standard Parks)"
            ],
            "range": ["#2ca25f", "#d62728"]
          },
          "legend": {
            "title": "Conservation Management Status",
            "orient": "bottom",
            "offset": 20
          }
        },
        "tooltip": [
          {"field": "Year", "type": "quantitative", "title": "Year", "format": "d"},
          {"field": "Management", "type": "nominal", "title": "Management"},
          {"field": "Index_Value", "type": "quantitative", "title": "Abundance Index", "format": ".2f"}
        ]
      }
    }
  ]
}
