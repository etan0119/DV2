{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "The Accelerating Expansion of Conservation",
    "subtitle": "Cumulative Protected Area over Time (Hectares)",
    "anchor": "start"
  },
  "width": "container",
  "height": 400,
  "data": {
    "url": "data/capad_metadata.csv",
    "format": {"type": "csv"}
  },
  "params": [
    {
      "name": "State_selection",
      "bind": {
        "input": "select",
        "options": [
          null,
          "NSW",
          "VIC",
          "QLD",
          "SA",
          "WA",
          "TAS",
          "NT",
          "ACT",
          "COM"
        ],
        "labels": [
          "Show All",
          "New South Wales",
          "Victoria",
          "Queensland",
          "South Australia",
          "Western Australia",
          "Tasmania",
          "Northern Territory",
          "Australian Capital Territory",
          "Commonwealth"
        ],
        "name": "Select State: "
      }
    }
  ],
  "layer": [
    {
      "transform": [
        {"filter": "datum.GAZ_DATE != null && datum.GAZ_AREA > 0"},
        {"calculate": "year(datum.GAZ_DATE)", "as": "Year"},
        {"filter": "State_selection == null || datum.STATE == State_selection"},
        {"aggregate": [{"op": "sum", "field": "GAZ_AREA", "as": "Total_Area"}], "groupby": ["Year"]},
        {"sort": [{"field": "Year"}], "window": [{"op": "sum", "field": "Total_Area", "as": "Cumulative_Area"}]}
      ],
      "mark": {"type": "area", "color": "#1a4301", "line": true, "opacity": 0.7},
      "encoding": {
        "x": {"field": "Year", "type": "temporal", "title": "Year"},
        "y": {"field": "Cumulative_Area", "type": "quantitative", "title": "Total Area (Hectares)"},
        "tooltip": [
          {"field": "Year", "type": "temporal", "title": "Year"},
          {"field": "Cumulative_Area", "type": "quantitative", "title": "Cumulative Area (ha)", "format": ","}
        ]
      }
    },
    {
      "data": {"values": [{"Year": 1999, "Text": "EPBC Act 1999"}]},
      "mark": {"type": "rule", "color": "#d95f02", "strokeWidth": 2, "strokeDash": [4, 4]},
      "encoding": {
        "x": {"field": "Year", "type": "temporal"}
      }
    },
    {
      "data": {"values": [{"Year": 1999, "Cumulative_Area": 50000000, "Text": "EPBC Act 1999"}]},
      "mark": {"type": "text", "align": "left", "dx": 5, "dy": -100, "color": "#d95f02", "fontWeight": "bold"},
      "encoding": {
        "x": {"field": "Year", "type": "temporal"},
        "text": {"field": "Text"}
      }
    }
  ]
}
