{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "The Accelerating Expansion of Conservation",
    "subtitle": "Cumulative Protected Area over Time (Hectares)",
    "anchor": "start",
    "offset": 20
  },
  "width": "container",
  "height": 400,
  "config": {
    "font": "Open Sans",
    "title": {
      "font": "Montserrat",
      "fontSize": 16,
      "fontWeight": "bold"
    },
    "axis": {
      "labelFont": "Open Sans",
      "titleFont": "Montserrat",
      "titleFontSize": 12,
      "titleFontWeight": "bold"
    },
    "legend": {
      "titleFont": "Montserrat",
      "titleFontSize": 12,
      "labelFont": "Open Sans",
      "labelFontSize": 11
    }
  },
  "data": {
    "url": "data/capad_metadata.csv",
    "format": {"type": "csv"}
  },
  "params": [
    {
      "name": "State_selection",
      "bind": {
        "input": "select",
        "options": [
          null,
          "NSW",
          "VIC",
          "QLD",
          "SA",
          "WA",
          "TAS",
          "NT",
          "ACT",
          "COM"
        ],
        "labels": [
          "Show All",
          "New South Wales",
          "Victoria",
          "Queensland",
          "South Australia",
          "Western Australia",
          "Tasmania",
          "Northern Territory",
          "Australian Capital Territory",
          "Commonwealth"
        ],
        "name": "Select State: "
      }
    }
  ],
  "layer": [
    {
      "transform": [
        {"filter": "datum.GAZ_DATE != null && datum.GIS_AREA > 0"},
        {"calculate": "year(datum.GAZ_DATE)", "as": "Year"},
        {"filter": "datum.Year <= 2024"},
        {"filter": "State_selection == null || datum.STATE == State_selection"},
        {"aggregate": [{"op": "sum", "field": "GIS_AREA", "as": "Total_Area"}], "groupby": ["Year"]},
        {"impute": "Total_Area", "key": "Year", "keyvals": [2024], "value": 0},
        {"sort": [{"field": "Year"}], "window": [{"op": "sum", "field": "Total_Area", "as": "Cumulative_Area"}]}
      ],
      "mark": {"type": "area", "color": "#1a4301", "line": true, "opacity": 0.7, "interpolate": "step-after"},
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "title": "Year",
          "axis": {"format": "d"},
          "scale": {"domainMax": 2024, "nice": false}
        },
        "y": {"field": "Cumulative_Area", "type": "quantitative", "title": "Total Area (Hectares)"},
        "tooltip": [
          {"field": "Year", "type": "quantitative", "title": "Year", "format": "d"},
          {"field": "Cumulative_Area", "type": "quantitative", "title": "Cumulative Area (ha)", "format": ","}
        ]
      }
    },
    {
      "data": {"values": [{"Year": 1999, "Text": "EPBC Act 1999"}]},
      "mark": {"type": "rule", "color": "#d95f02", "strokeWidth": 2, "strokeDash": [4, 4]},
      "encoding": {
        "x": {"field": "Year", "type": "quantitative"}
      }
    },
    {
      "data": {"values": [{"Year": 1999, "Text": "EPBC Act 1999"}]},
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 5,
        "y": 20,
        "color": "#d95f02",
        "fontWeight": "bold"
      },
      "encoding": {
        "x": {"field": "Year", "type": "quantitative"},
        "text": {"field": "Text"}
      }
    }
  ]
}
