{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Gap Analysis: Terrestrial vs. Marine Latitudinal Trends",
    "subtitle": "Mean Area trend per latitude (Log Scale)",
    "anchor": "start",
    "offset": 20
  },
  "data": {
    "url": "data/capad_metadata.csv",
    "format": {"type": "csv"}
  },
  "params": [
    {
      "name": "active_step",
      "value": 1
    }
  ],
  "transform": [
    {
      "filter": "datum.GIS_AREA > 0 && datum.LATITUDE != null"
    },
    {
      "calculate": "datum.STATE == 'VIC' ? 'Victoria' : datum.STATE == 'NSW' ? 'New South Wales' : datum.STATE == 'QLD' ? 'Queensland' : datum.STATE == 'SA' ? 'South Australia' : datum.STATE == 'WA' ? 'Western Australia' : datum.STATE == 'TAS' ? 'Tasmania' : datum.STATE == 'NT' ? 'Northern Territory' : datum.STATE == 'ACT' ? 'Australian Capital Territory' : datum.STATE == 'COM' ? 'Commonwealth' : datum.STATE == 'EXT' ? 'External Territory' : datum.STATE",
      "as": "State_Full"
    },
    {
      "calculate": "datum.ENVIRON == 'T' ? 'Terrestrial' : 'Marine'",
      "as": "Env_Full"
    },
    {
      "calculate": "floor(datum.LATITUDE)",
      "as": "Lat_Bin"
    }
  ],
  "hconcat": [
    {
      "title": "Terrestrial Reserves",
      "transform": [{"filter": "datum.Env_Full == 'Terrestrial'"}],
      "width": 260,
      "height": 400,
      "layer": [
        {
          "params": [
            {
              "name": "State_Selection",
              "select": {"type": "point", "fields": ["State_Full"]},
              "bind": "legend"
            }
          ],
          "mark": {"type": "point", "filled": true},
          "encoding": {
            "x": {
              "field": "LATITUDE",
              "type": "quantitative",
              "title": "Latitude (Degrees South)"
            },
            "y": {
              "field": "GIS_AREA",
              "type": "quantitative",
              "scale": {"type": "log"},
              "title": "Area (ha, Log Scale)"
            },
            "color": {
              "field": "State_Full",
              "type": "nominal",
              "legend": {"orient": "right", "title": "State/Territory", "titleLimit": 200}
            },
            "opacity": {
              "condition": [
                {
                  "test": "active_step == 2 && (datum.STATE == 'COM' || datum.STATE == 'EXT')",
                  "value": 0.8
                },
                {
                  "test": "active_step == 3 && (datum.STATE != 'COM' && datum.STATE != 'EXT')",
                  "value": 0.8
                },
                {
                  "test": "active_step == 1",
                  "condition": {"param": "State_Selection", "value": 0.3},
                  "value": 0.05
                }
              ],
              "value": 0.05
            },
            "size": {"value": 15}
          }
        },
        {
          "transform": [
            {"filter": "active_step == 1 || (active_step == 2 && (datum.STATE == 'COM' || datum.STATE == 'EXT')) || (active_step == 3 && (datum.STATE != 'COM' && datum.STATE != 'EXT'))"},
            {
              "aggregate": [{"op": "mean", "field": "GIS_AREA", "as": "Mean_Area"}],
              "groupby": ["Lat_Bin"]
            }
          ],
          "mark": {
            "type": "line",
            "strokeWidth": 3,
            "opacity": 0.8,
            "color": "#d95f02"
          },
          "encoding": {
            "x": {"field": "Lat_Bin", "type": "quantitative"},
            "y": {"field": "Mean_Area", "type": "quantitative"}
          }
        }
      ]
    },
    {
      "title": "Marine Sanctuaries",
      "transform": [{"filter": "datum.Env_Full == 'Marine'"}],
      "width": 260,
      "height": 400,
      "layer": [
        {
          "mark": {"type": "point", "filled": true},
          "encoding": {
            "x": {
              "field": "LATITUDE",
              "type": "quantitative",
              "title": "Latitude (Degrees South)"
            },
            "y": {
              "field": "GIS_AREA",
              "type": "quantitative",
              "scale": {"type": "log"},
              "title": null
            },
            "color": {
              "field": "State_Full",
              "type": "nominal",
              "legend": null
            },
            "opacity": {
              "condition": [
                {
                  "test": "active_step == 2 && (datum.STATE == 'COM' || datum.STATE == 'EXT')",
                  "value": 0.8
                },
                {
                  "test": "active_step == 3 && (datum.STATE != 'COM' && datum.STATE != 'EXT')",
                  "value": 0.8
                },
                {
                  "test": "active_step == 1",
                  "condition": {"param": "State_Selection", "value": 0.3},
                  "value": 0.05
                }
              ],
              "value": 0.05
            },
            "size": {"value": 15}
          }
        },
        {
          "transform": [
            {"filter": "active_step == 1 || (active_step == 2 && (datum.STATE == 'COM' || datum.STATE == 'EXT')) || (active_step == 3 && (datum.STATE != 'COM' && datum.STATE != 'EXT'))"},
            {
              "aggregate": [{"op": "mean", "field": "GIS_AREA", "as": "Mean_Area"}],
              "groupby": ["Lat_Bin"]
            }
          ],
          "mark": {
            "type": "line",
            "strokeWidth": 3,
            "opacity": 0.8,
            "color": "#d95f02"
          },
          "encoding": {
            "x": {"field": "Lat_Bin", "type": "quantitative"},
            "y": {"field": "Mean_Area", "type": "quantitative"}
          }
        }
      ]
    }
  ],
  "config": {
    "view": {"stroke": null}
  }
}
