{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 550,
  "background": "#f0f8ff",
  "title": {
    "text": "State-by-State Conservation Gap Analysis",
    "subtitle": {
      "signal": "active_step == 1 ? 'Terrestrial Protection Coverage (% of land protected)' : active_step == 2 ? 'State Marine Sanctuaries (Total area in hectares)' : 'Mean Terrestrial Park Size (Deserts vs. Southern fragments)'"
    },
    "anchor": "start",
    "offset": 20
  },
  "projection": {
    "type": "mercator",
    "center": [133.7751, -25.2744],
    "scale": 700
  },
  "config": {
    "font": "Open Sans",
    "title": {
      "font": "Montserrat",
      "fontSize": 16,
      "fontWeight": "bold"
    },
    "legend": {
      "titleFont": "Montserrat",
      "titleFontSize": 12,
      "labelFont": "Open Sans",
      "labelFontSize": 11
    },
    "view": {"stroke": null}
  },
  "params": [
    {
      "name": "active_step",
      "value": 1
    }
  ],
  "data": {
    "url": "https://raw.githubusercontent.com/tonywr71/GeoJson-Data/master/australian-states.json",
    "format": {"type": "json", "property": "features"}
  },
  "transform": [
    {
      "lookup": "properties.STATE_NAME",
      "from": {
        "data": {
          "url": "data/state_gap_metrics.csv",
          "format": {
            "type": "csv",
            "parse": {
              "Terrestrial_Protected_Percent": "number",
              "Terrestrial_Protected_ha": "number",
              "Land_Area_ha": "number",
              "Marine_Protected_ha": "number",
              "Marine_Count": "number",
              "Mean_Terrestrial_Size_ha": "number",
              "Terrestrial_Count": "number"
            }
          }
        },
        "key": "STATE_NAME",
        "fields": [
          "Terrestrial_Protected_Percent",
          "Terrestrial_Protected_ha",
          "Land_Area_ha",
          "Marine_Protected_ha",
          "Marine_Count",
          "Mean_Terrestrial_Size_ha",
          "Terrestrial_Count"
        ]
      }
    },
    {
      "calculate": "active_step == 1 ? datum.Terrestrial_Protected_Percent : active_step == 2 ? max(datum.Marine_Protected_ha, 0.1) : datum.Mean_Terrestrial_Size_ha",
      "as": "Map_Value"
    }
  ],
  "mark": {
    "type": "geoshape",
    "stroke": "white",
    "strokeWidth": 1
  },
  "encoding": {
    "color": {
      "field": "Map_Value",
      "type": "quantitative",
      "scale": {
        "type": "log",
        "scheme": "yellowgreenblue"
      },
      "legend": {
        "title": {"signal": "active_step == 1 ? 'Land Protected (%)' : active_step == 2 ? 'Marine Protected (ha)' : 'Mean Reserve Size (ha)'"},
        "orient": "bottom-left",
        "format": ","
      }
    },
    "tooltip": [
      {"field": "properties.STATE_NAME", "type": "nominal", "title": "State/Territory"},
      {"field": "Land_Area_ha", "type": "quantitative", "title": "Total Land Area (ha)", "format": ","},
      {"field": "Terrestrial_Protected_Percent", "type": "quantitative", "title": "Terrestrial Protected (%)", "format": ".1f"},
      {"field": "Marine_Protected_ha", "type": "quantitative", "title": "Marine Protected (ha)", "format": ","},
      {"field": "Mean_Terrestrial_Size_ha", "type": "quantitative", "title": "Mean Terrestrial Size (ha)", "format": ","}
    ]
  }
}
