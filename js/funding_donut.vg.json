{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Who Watches Over the Wild?",
    "subtitle": "Top 10 Conservation Authorities by Sites Managed",
    "anchor": "start"
  },
  "width": "container",
  "height": 300,
  "autosize": {"type": "fit", "contains": "padding"},
  "config": {
    "font": "Open Sans",
    "title": {
      "font": "Montserrat",
      "fontSize": 14,
      "fontWeight": "bold"
    },
    "axis": {
      "labelFont": "Open Sans",
      "titleFont": "Montserrat",
      "titleFontSize": 11,
      "titleFontWeight": "bold"
    }
  },
  "data": {
    "url": "data/capad_metadata.csv",
    "format": {"type": "csv"}
  },
  "transform": [
    {
      "calculate": "datum.AUTHORITY == 'VIC_DEECA' ? 'DEECA (Victoria)' : datum.AUTHORITY == 'NRE_TAS' ? 'NRE (Tasmania)' : datum.AUTHORITY == 'SA_DEW' ? 'DEW (South Australia)' : datum.AUTHORITY == 'WA_DBCA' ? 'DBCA (Western Australia)' : datum.AUTHORITY == 'QLD_DES' ? 'DES (Queensland)' : datum.AUTHORITY == 'NSW_DCCEEW' ? 'DCCEEW (NSW)' : datum.AUTHORITY == 'DCCEEW' ? 'DCCEEW (Commonwealth)' : datum.AUTHORITY == 'ACT_EPSDD' ? 'EPSDD (ACT)' : datum.AUTHORITY == 'TAS_PRIV' ? 'Private (Tasmania)' : datum.AUTHORITY == 'NT_PWCNT' ? 'Parks & Wildlife (NT)' : datum.AUTHORITY",
      "as": "Authority_Full"
    },
    {
      "aggregate": [{"op": "count", "as": "count"}],
      "groupby": ["Authority_Full"]
    },
    {
      "window": [{"op": "rank", "as": "rank"}],
      "sort": [{"field": "count", "order": "descending"}]
    },
    {
      "filter": "datum.rank <= 10"
    }
  ],
  "layer": [
    {
      "mark": {"type": "bar", "size": 2, "color": "#d0d0d0"},
      "encoding": {
        "y": {
          "field": "Authority_Full",
          "type": "nominal",
          "title": null,
          "sort": {"field": "count", "order": "descending"}
        },
        "x": {
          "field": "count",
          "type": "quantitative",
          "title": "Number of Protected Sites Managed",
          "scale": {"domainMax": 7000}
        }
      }
    },
    {
      "mark": {"type": "circle", "size": 100, "opacity": 1, "color": "#1a4301"},
      "encoding": {
        "y": {
          "field": "Authority_Full",
          "type": "nominal",
          "sort": {"field": "count", "order": "descending"}
        },
        "x": {
          "field": "count",
          "type": "quantitative"
        },
        "tooltip": [
          {"field": "Authority_Full", "type": "nominal", "title": "Authority"},
          {"field": "count", "type": "quantitative", "title": "Sites Managed", "format": ","}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 10,
        "dy": 0,
        "fontWeight": "bold",
        "fontSize": 10,
        "color": "#2c3e50"
      },
      "encoding": {
        "y": {
          "field": "Authority_Full",
          "type": "nominal",
          "sort": {"field": "count", "order": "descending"}
        },
        "x": {
          "field": "count",
          "type": "quantitative"
        },
        "text": {
          "field": "count",
          "type": "quantitative",
          "format": ","
        }
      }
    }
  ]
}
